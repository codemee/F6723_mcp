{
  "mcp_servers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "openclaw Docs": {
      "url": "https://gitmcp.io/openclaw/openclaw"
    },
    "brave-search": {
      "type": "http",
